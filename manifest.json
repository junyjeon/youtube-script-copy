{
  "manifest_version": 3,
  "name": "YouTube Script Copy",
  "version": "1.1",
  "description": "Extract and copy YouTube subtitles to clipboard — no background processes, no slowdowns.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "scripting"
  ],
  "host_permissions": [
    "https://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "favicon_io/favicon-16x16.png",
    "32": "favicon_io/favicon-32x32.png",
    "48": "favicon_io/android-chrome-192x192.png",
    "128": "favicon_io/android-chrome-512x512.png"
  }
}
